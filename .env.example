# Credenciales OAuth2 (client_credentials) de Siglo 21 — las mismas que usa el
# lambda siglo21-price-proxy contra https://auth.ues21.edu.ar/menu/api/oauth2/token
SIGLO21_CLIENT_ID=
SIGLO21_CLIENT_SECRET=

# Opcionales — para apuntar a otro entorno (default: producción)
# QA: https://price-simulator-facade-qa.uesiglo21.edu.ar/api/v1
SIGLO21_BASE_URL=
SIGLO21_AUTH_URL=
